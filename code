import sys
import math

from PyQt6.QtWidgets import (
    QApplication,
    QMainWindow,
    QWidget,
    QVBoxLayout,
    QHBoxLayout,
    QGridLayout,
    QPushButton,
    QTextEdit,
    QLineEdit
)

from PyQt6.QtGui import QAction


class Calculator(QMainWindow):

    def __init__(self):
        super().__init__()

        self.memory = 0

        self.setWindowTitle("Advanced Engineering Calculator")
        self.resize(1200, 700)

        self.setup_ui()

    def setup_ui(self):

        menubar = self.menuBar()

        theme_menu = menubar.addMenu("Theme")
        mode_menu = menubar.addMenu("Mode")

        dark_action = QAction("Dark Theme", self)
        light_action = QAction("Light Theme", self)

        dark_action.triggered.connect(self.dark_theme)
        light_action.triggered.connect(self.light_theme)

        theme_menu.addAction(dark_action)
        theme_menu.addAction(light_action)

        mode_menu.addAction("Standard")
        mode_menu.addAction("Scientific")
        mode_menu.addAction("Programmer")

        central = QWidget()
        self.setCentralWidget(central)

        main_layout = QHBoxLayout(central)

        left_layout = QVBoxLayout()

        self.expression = QLineEdit()
        self.expression.setPlaceholderText("Enter Expression")
        self.expression.setMinimumHeight(60)

        self.result = QLineEdit()
        self.result.setReadOnly(True)
        self.result.setMinimumHeight(80)

        left_layout.addWidget(self.expression)
        left_layout.addWidget(self.result)

        # Memory Buttons
        memory_layout = QGridLayout()

        memory_buttons = ["MC", "MR", "M+", "M-", "MS"]

        for col, text in enumerate(memory_buttons):
            btn = QPushButton(text)
            btn.clicked.connect(self.memory_click)
            memory_layout.addWidget(btn, 0, col)

        left_layout.addLayout(memory_layout)

        # Scientific Buttons
        scientific_layout = QGridLayout()

        scientific_buttons = [
            ["sin", "cos", "tan", "log"],
            ["ln", "π", "e", "√"],
            ["x²", "x³", "!", "C"]
        ]

        for row in range(len(scientific_buttons)):
            for col in range(len(scientific_buttons[row])):

                btn = QPushButton(scientific_buttons[row][col])
                btn.setMinimumHeight(60)
                btn.clicked.connect(self.scientific_click)

                scientific_layout.addWidget(btn, row, col)

        left_layout.addLayout(scientific_layout)

        # Number Pad
        number_layout = QGridLayout()

        buttons = [
            ['(', ')', '%', '/'],
            ['7', '8', '9', '*'],
            ['4', '5', '6', '-'],
            ['1', '2', '3', '+'],
            ['0', '.', '=', '']
        ]

        for row in range(len(buttons)):
            for col in range(len(buttons[row])):

                text = buttons[row][col]

                if text == "":
                    continue

                btn = QPushButton(text)
                btn.setMinimumHeight(75)
                btn.clicked.connect(self.button_click)

                number_layout.addWidget(btn, row, col)

        left_layout.addLayout(number_layout)

        # History
        self.history = QTextEdit()
        self.history.setReadOnly(True)
        self.history.setPlaceholderText("Calculation History")
        self.history.setMinimumWidth(320)

        main_layout.addLayout(left_layout, 3)
        main_layout.addWidget(self.history, 1)

        self.dark_theme()

    def button_click(self):

        text = self.sender().text()

        if text == "=":

            try:
                expression = self.expression.text()

                result = eval(expression)

                self.result.setText(str(result))

                self.history.append(
                    f"{expression} = {result}"
                )

            except:
                self.result.setText("Error")

        else:
            self.expression.setText(
                self.expression.text() + text
            )

    def scientific_click(self):

        text = self.sender().text()

        try:

            if text == "C":
                self.expression.clear()
                self.result.clear()
                return

            expr = self.expression.text()

            if text == "π":
                self.expression.setText(
                    expr + str(math.pi)
                )

            elif text == "e":
                self.expression.setText(
                    expr + str(math.e)
                )

            elif text == "√":
                self.expression.setText(
                    expr + "**0.5"
                )

            elif text == "x²":
                self.expression.setText(
                    expr + "**2"
                )

            elif text == "x³":
                self.expression.setText(
                    expr + "**3"
                )

            elif text == "sin":

                value = float(expr)

                result = math.sin(
                    math.radians(value)
                )

                self.result.setText(str(result))

            elif text == "cos":

                value = float(expr)

                result = math.cos(
                    math.radians(value)
                )

                self.result.setText(str(result))

            elif text == "tan":

                value = float(expr)

                result = math.tan(
                    math.radians(value)
                )

                self.result.setText(str(result))

            elif text == "log":

                value = float(expr)

                result = math.log10(value)

                self.result.setText(str(result))

            elif text == "ln":

                value = float(expr)

                result = math.log(value)

                self.result.setText(str(result))

            elif text == "!":

                value = int(float(expr))

                result = math.factorial(value)

                self.result.setText(str(result))

        except:
            self.result.setText("Error")

    def memory_click(self):

        action = self.sender().text()

        try:

            if action == "MC":
                self.memory = 0

            elif action == "MR":
                self.expression.setText(
                    str(self.memory)
                )

            elif action == "MS":
                self.memory = float(
                    self.result.text()
                )

            elif action == "M+":
                self.memory += float(
                    self.result.text()
                )

            elif action == "M-":
                self.memory -= float(
                    self.result.text()
                )

        except:
            pass

    def dark_theme(self):

        self.setStyleSheet("""
        QMainWindow {
            background:#202124;
        }

        QPushButton {
            background:#303134;
            color:white;
            border:none;
            border-radius:10px;
            font-size:16px;
            padding:10px;
        }

        QPushButton:hover {
            background:#3c4043;
        }

        QLineEdit {
            background:#171717;
            color:white;
            border:none;
            font-size:24px;
            padding:12px;
        }

        QTextEdit {
            background:#171717;
            color:white;
            font-size:14px;
        }

        QMenuBar {
            background:#202124;
            color:white;
        }

        QMenu {
            background:#202124;
            color:white;
        }
        """)

    def light_theme(self):
        self.setStyleSheet("")


if __name__ == "__main__":

    app = QApplication(sys.argv)

    window = Calculator()
    window.show()

    sys.exit(app.exec())
